# PUBLIC API — mce:api/util/help
# MCE version: 1.1.0

tellraw @s ["",{"text":"=== MCE v1.1.0 ===","color":"gold"}]
tellraw @s ["",{"text":"--- Run ---","color":"yellow"}]
tellraw @s ["",{"text":"  data modify storage mce:cmd Command set value \"<cmd>\"","color":"white"}]
tellraw @s ["",{"text":"  function mce:api/run/cmd","color":"gray"}]
tellraw @s ["",{"text":"--- Run As Entity ---","color":"yellow"}]
tellraw @s ["",{"text":"  tag <selector> add mce.executor","color":"white"}]
tellraw @s ["",{"text":"  data modify storage mce:cmd Command set value \"<cmd>\"","color":"white"}]
tellraw @s ["",{"text":"  function mce:api/run/as","color":"gray"}]
tellraw @s ["",{"text":"  (mce.executor tag removed automatically)","color":"dark_gray"}]
tellraw @s ["",{"text":"--- Queue ---","color":"yellow"}]
tellraw @s ["",{"text":"  data modify storage mce:cmd Command set value \"<cmd>\"","color":"white"}]
tellraw @s ["",{"text":"  function mce:api/queue/add   (repeat for each command)","color":"gray"}]
tellraw @s ["",{"text":"  function mce:api/queue/run   (start)","color":"gray"}]
tellraw @s ["",{"text":"  function mce:api/queue/clear (cancel)","color":"gray"}]
tellraw @s ["",{"text":"--- Batch ---","color":"yellow"}]
tellraw @s ["",{"text":"  data modify storage mce:batch commands set value [\"<cmd1>\",\"<cmd2>\",...]","color":"white"}]
tellraw @s ["",{"text":"  function mce:api/batch/run              (add to queue and run)","color":"gray"}]
tellraw @s ["",{"text":"  function mce:api/batch/clear            (discard without queuing)","color":"gray"}]
tellraw @s ["",{"text":"--- Schedule ---","color":"yellow"}]
tellraw @s ["",{"text":"  data modify storage mce:cmd Command set value \"<cmd>\"","color":"white"}]
tellraw @s ["",{"text":"  data modify storage mce:cmd Delay set value <ticks>","color":"white"}]
tellraw @s ["",{"text":"  function mce:api/schedule/run           (queue for later)","color":"gray"}]
tellraw @s ["",{"text":"  function mce:api/schedule/clear         (cancel all pending)","color":"gray"}]
tellraw @s ["",{"text":"--- Util ---","color":"yellow"}]
tellraw @s ["",{"text":"  function mce:api/util/cancel            (abort active command)","color":"gray"}]
tellraw @s ["",{"text":"  function mce:api/util/debug_toggle      (toggle debug output)","color":"gray"}]
